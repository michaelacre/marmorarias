-- =========================================================
-- CRISTALLO MÁRMORES & GRANITOS — SETUP DO BANCO (Supabase)
-- Cole tudo isso no SQL Editor do seu projeto e clique em "Run"
-- =========================================================

-- 0) Remove qualquer tabela "produtos" antiga com esquema diferente
--    (seguro aqui porque é uma tabela nova, só pra essa demonstração)
drop table if exists produtos cascade;

-- 1) Tabela de produtos (tipos de mármore/granito)
create table produtos (
  id uuid primary key default gen_random_uuid(),
  nome text not null,
  tipo text not null,               -- ex: 'Mármore' ou 'Granito'
  origem text,                      -- ex: 'Itália', 'Espírito Santo - BR'
  cor_predominante text,
  preco_m2 numeric(10,2) not null,
  descricao text,
  imagem_keyword text not null,     -- usada para casar com o nome do arquivo no Storage
  destaque boolean default false,
  ordem integer default 0,
  created_at timestamptz default now()
);

-- 2) Ativa Row Level Security
alter table produtos enable row level security;

-- 3) Política: qualquer visitante do site pode LER os produtos
--    (mas ninguém de fora consegue inserir/editar/apagar)
drop policy if exists "Leitura publica de produtos" on produtos;
create policy "Leitura publica de produtos"
  on produtos for select
  using (true);


-- =========================================================
-- 5) LIBERA A LISTAGEM DO BUCKET DE IMAGENS
--    Marcar o bucket como "Public" libera o download direto de
--    cada arquivo, mas NÃO libera a operação de listar os arquivos
--    (usada pelo site pra casar cada produto com a imagem certa).
--    Sem essa política, o site cai sempre na imagem de reserva.
-- =========================================================
drop policy if exists "Leitura publica de arquivos - galeria-marmore" on storage.objects;
create policy "Leitura publica de arquivos - galeria-marmore"
  on storage.objects for select
  to public
  using ( bucket_id = 'galeria-marmore' );
